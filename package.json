{
  "name": "hand-terminal",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=website",
    "start": "turbo run start",
    "android": "turbo run android",
    "ios": "turbo run ios",
    "web": "turbo run web",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
